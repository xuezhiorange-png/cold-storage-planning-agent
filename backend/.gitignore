# Task 11B Path A A1 allowlist: keep generic evaluation/ guardrail,
# but permit the frozen A1 adapter and tests explicitly.
!backend/src/cold_storage/evaluation/
backend/src/cold_storage/evaluation/*
!backend/src/cold_storage/evaluation/__init__.py
!backend/src/cold_storage/evaluation/adapter.py
!backend/tests/evaluation/
backend/tests/evaluation/*
!backend/tests/evaluation/__init__.py
!backend/tests/evaluation/test_path_a_adapter.py
# A1 follow-up slice: also permit the test-side pre-existing-context
# seed helper. The helper is path-precise (only this file) and
# purpose-bound (test-only pre-existing production row setup; not
# production_seeding.py, not raw ORM fabrication in production code,
# not in the adapter or runner).
!backend/tests/evaluation/_seed_helpers.py
# A1.5 implementation slice: also permit the runner stack + acceptance suites.
# Files added by the A1.5 docs-only verification correction round.
# The runner does NOT take a ``project_input`` (A1-2a surface), does
# NOT write production rows, does NOT bypass
# ``compose_production_scheme_service``, and does NOT raise on the
# happy path (pre-freeze §1.3 #1 + §1.5). The acceptance suites are
# test-only and use the test-side pre-existing-context seed helper
# (already permitted by the A1 follow-up slice above).
!backend/src/cold_storage/evaluation/errors.py
!backend/src/cold_storage/evaluation/execute.py
!backend/src/cold_storage/evaluation/run_directory.py
!backend/src/cold_storage/evaluation/cli.py
!backend/tests/evaluation/test_sqlite_acceptance.py
!backend/tests/evaluation/test_postgresql_acceptance.py
!backend/tests/evaluation/test_cli.py
!backend/tests/evaluation/test_fixture_consistency.py

