{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xuezhiorange-png/cold-storage-planning-agent/manifest.schema.json",
  "title": "TASK-011C V1 Manifest",
  "description": "V1 manifest for the evaluation framework. schema_version is the literal string \"1.0\" (D5). D3: excluded_paths must be the empty array. No undeclared fields are permitted (extra=forbid in pydantic).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "suite_id", "scenarios"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Literal string \"1.0\" (D5). Numeric 1.0 is rejected. Unknown versions are rejected. Backward / forward compatibility is fail-closed."
    },
    "suite_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier for the run-suite."
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scenario" }
    },
    "provenance": { "$ref": "#/$defs/provenance" },
    "excluded_paths": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 0,
      "description": "D3 approval: V1 exclusion set is the empty array. Any non-empty value is rejected (D3 binding)."
    }
  },
  "$defs": {
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario_id", "database_backend", "expected_outcome"],
      "properties": {
        "scenario_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
        },
        "database_backend": {
          "type": "string",
          "enum": ["sqlite", "postgresql"]
        },
        "expected_outcome": {
          "type": "string",
          "enum": ["SUCCEEDED", "BLOCKED", "INVALID_INPUT"]
        },
        "fixtures": {
          "type": "array",
          "items": { "$ref": "#/$defs/fixture_ref" }
        },
        "expected_output": { "$ref": "#/$defs/expected_output_ref" },
        "comparison_policy": { "$ref": "#/$defs/comparison_policy" },
        "notes": { "type": ["string", "null"] }
      }
    },
    "fixture_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture_id", "path"],
      "properties": {
        "fixture_id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "expected_output_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario_id", "expected_outcome"],
      "properties": {
        "scenario_id": { "type": "string", "minLength": 1 },
        "path": { "type": ["string", "null"] },
        "expected_outcome": {
          "type": "string",
          "enum": ["SUCCEEDED", "BLOCKED", "INVALID_INPUT"]
        },
        "commit_sha": { "type": ["string", "null"] },
        "expected_error": { "$ref": "#/$defs/expected_error" }
      }
    },
    "expected_error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exception_type", "code", "field"],
      "properties": {
        "exception_type": { "type": "string", "minLength": 1 },
        "code": { "type": "string", "minLength": 1 },
        "field": { "type": "string", "minLength": 1 }
      }
    },
    "comparison_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "leaves": {
          "type": "array",
          "items": { "$ref": "#/$defs/comparison_policy_leaf" }
        }
      }
    },
    "comparison_policy_leaf": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind"],
      "properties": {
        "path": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["exact", "decimal"],
          "description": "V1 comparison kind. EXCLUDED was removed (D3 V1 empty exclusion set; review 4689545688 P0-3). Wildcards, tolerances, and excluded kinds are not permitted in V1."
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "authored_by": { "type": ["string", "null"] },
        "authored_at": { "type": ["string", "null"] },
        "source_contract": { "type": ["string", "null"] },
        "contract_authority_comment_id": { "type": ["integer", "null"] }
      }
    }
  }
}
